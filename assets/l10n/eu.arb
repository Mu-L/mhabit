{
    "@@locale": "eu",
    "localeScriptName": "Euskara",
    "@localeScriptName": {
        "description": "The human-readable name of the language used for the locale."
    },
    "appName": "🚧(eu) - Table Habit",
    "changelog_banner_title": "What's New in v{version}",
    "@changelog_banner_title": {
        "description": "Title in the MaterialBanner showing the current version changelog on first open after upgrade.",
        "placeholders": {
            "version": {
                "type": "String",
                "example": "1.25.3+168"
            }
        }
    },
    "changelog_banner_action": "CLOSE",
    "@changelog_banner_action": {
        "description": "Dismiss button label on the changelog MaterialBanner."
    },
    "changelog_banner_view": "VIEW",
    "@changelog_banner_view": {
        "description": "View button label on the changelog MaterialBanner that opens the full changelog dialog."
    },
    "changelog_dialog_title": "Changelog",
    "changelog_view_full": "View Full Changelog",
    "@changelog_view_full": {
        "description": "Button label inside the changelog dialog to toggle from current-version-only to full CHANGELOG.md content."
    }
}
